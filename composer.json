{
    "name": "konekt/git-php",
    "description": "Easy to use GIT wrapper for PHP.",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "psr/log": "^1.0|^2.0|^3.0",
        "symfony/process": "^6.0 || ^7.0"
    },
    "require-dev": {
        "symfony/filesystem": "^6.0 || ^7.0",
        "phpunit/phpunit": "9 - 10"
    },
    "autoload": {
        "psr-4": {
            "Konekt\\GitPhp\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Konekt\\GitPhp\\Test\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.0-dev"
        }
    }
}
